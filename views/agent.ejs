 <link rel="stylesheet" href="/agent.css" />


<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <h2 class="text-white">Agent Dashboard</h2>
            <hr style="border-color: gray;">
        </div>
    </div>

    <div class="card bg-dark text-white mb-4">
        <div class="card-body text-center">
            <h5>Ang Iyong Referral Link</h5>
            <p class="text-muted">I-copy ang link na ito at i-send sa iyong mga players.</p>
            <div class="input-group mb-3">
                <input type="text" class="form-control text-center" id="refLink" value="<%= referralLink %>" readonly>
                <button class="btn btn-primary" onclick="copyLink()">Copy Link</button>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card bg-success text-white mb-4">
                <div class="card-body text-center">
                    <h6>Total Commissions</h6>
                    <h3>₱<%= (stats.total_earnings || 0).toLocaleString() %></h3>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card bg-info text-white mb-4">
                <div class="card-body text-center">
                    <h6>Total Players</h6>
                    <h3><%= players.length %></h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card bg-dark text-white">
        <div class="card-header">Listahan ng Iyong mga Players</div>
        <div class="card-body">
            <table class="table table-dark table-striped">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Joined Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (players.length > 0) { %>
                        <% players.forEach(p => { %>
                            <tr>
                                <td><%= p.name %></td>
                                <td><%= new Date(p.created_at).toLocaleDateString() %></td>
                                <td><span class="badge bg-success">Active</span></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" class="text-center text-muted">Wala ka pang players sa ngayon.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
function copyLink() {
    var copyText = document.getElementById("refLink");
    copyText.select();
    copyText.setSelectionRange(0, 99999); // Para sa mobile
    navigator.clipboard.writeText(copyText.value);
    alert("Copied: " + copyText.value);
}
</script>
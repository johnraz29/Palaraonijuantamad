<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Place Bet</title>
    <link rel="stylesheet" href="/bet.css" />
</head>
<body>
<header>
    <div class="logo">
        <img src="/images/Logopalaronijuan.png" alt="Logo">
        <h1>Place Your Bet</h1>
    </div>
</header>

<main>
<section class="bet-section">
    <h2>Place Bet</h2>
    <p>Choose <strong>6 unique numbers</strong> between 1 and 50. Cost: ₱10</p>
    
    <form id="betForm" method="post" action="/bet">
        <div class="number-grid">
            <% for (let i = 1; i <= 50; i++) { %>
               <button onclick="return false;" type="button" class="number-btn" data-number="<%= i %>"><%= i %></button>
            <% } %>
        </div>
        <!-- Dito itatago ang 6 numbers para ma-submit sa server -->
        <input type="hidden" name="numbers" id="numbersInput" required>
        
        <div class="selected-numbers">
            <p>Selected Numbers: <span id="selectedNumbersDisplay">None</span></p>
        </div>
        <button type="submit" class="submit-btn">Place Bet (₱10)</button>
    </form>
</section>
</main>
<script>
document.addEventListener('DOMContentLoaded', function () {

    const maxNumbers = 6;
    const selectedNumbers = [];

    const buttons = document.querySelectorAll('.number-btn');
    const numbersInput = document.getElementById('numbersInput');
    const display = document.getElementById('selectedNumbersDisplay');
    const form = document.getElementById('betForm');

    function renderSelected() {

        // update hidden input
        numbersInput.value = selectedNumbers.join(',');

        // update display
        if (selectedNumbers.length > 0) {
            display.textContent = selectedNumbers.join(', ');
        } else {
            display.textContent = 'None';
        }

        // update buttons
        buttons.forEach(btn => {

            const value = Number(btn.dataset.number);

            if (selectedNumbers.includes(value)) {
                btn.classList.add('selected');
            } else {
                btn.classList.remove('selected');
            }

        });
    }

    buttons.forEach(btn => {

        btn.addEventListener('click', function (e) {

            e.preventDefault();

            const value = Number(this.dataset.number);

            const existingIndex = selectedNumbers.indexOf(value);

            // remove if already selected
            if (existingIndex !== -1) {

                selectedNumbers.splice(existingIndex, 1);

            } else {

                // limit to 6
                if (selectedNumbers.length >= maxNumbers) {
                    alert('You can only select 6 numbers.');
                    return;
                }

                selectedNumbers.push(value);
            }

            renderSelected();
        });

    });

    form.addEventListener('submit', function (e) {

        if (selectedNumbers.length !== 6) {

            e.preventDefault();
            alert('Please select exactly 6 numbers.');

        }

    });

});
</script>

<style>
    /* Siguraduhin na may visual feedback ang 'selected' class */
    .number-btn.selected {
        background-color: #ffc107 !important; /* Gold/Yellow */
        color: #000 !important;
        font-weight: bold;
        border: 2px solid #000;
    }
</style>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Place Bet</title>
<link rel="stylesheet" href="/bet.css" />
</head>
<body>
<header>
    <div class="logo">
        <img src="/images/Logopalaronijuan.png" alt="Logo">
        <h1>Place Your Bet</h1>
    </div>
</header>

<main>
<section class="bet-section">
    <h2>Place Bet</h2>
    <p>Choose <strong>6 unique numbers</strong> between 1 and 50. Cost: ₱10</p>
    
    <form id="betForm" method="post" action="/bet">
        <div class="number-grid">
            <% for (let i = 1; i <= 50; i++) { %>
                <button type="button" class="number-btn" data-number="<%= i %>"><%= i %></button>
            <% } %>
        </div>
        <input type="hidden" name="numbers" id="numbersInput" required>
        <div class="selected-numbers">
            <p>Selected Numbers: <span id="selectedNumbers">None</span></p>
        </div>
        <button type="submit" class="submit-btn">Place Bet (₱10)</button>
    </form>
</section>
</main>

<script>
document.addEventListener('DOMContentLoaded', () => {

    let selectedNumbers = [];
    const maxNumbers = 6;

    const buttons = document.querySelectorAll('.number-btn');
    const numbersInput = document.getElementById('numbersInput');
    const selectedNumbersDisplay = document.getElementById('selectedNumbers');

    buttons.forEach(btn => {

        btn.addEventListener('click', function(e) {

            e.preventDefault();

            const num = parseInt(this.dataset.number);

            // REMOVE NUMBER
            if (selectedNumbers.includes(num)) {

                selectedNumbers = selectedNumbers.filter(n => n !== num);

                this.classList.remove('selected');

            } 
            // ADD NUMBER
            else {

                if (selectedNumbers.length >= maxNumbers) {
                    alert('6 numbers only!');
                    return;
                }

                selectedNumbers.push(num);

                this.classList.add('selected');
            }

            // UPDATE DISPLAY
            numbersInput.value = selectedNumbers.join(',');

            selectedNumbersDisplay.textContent =
                selectedNumbers.length > 0
                ? selectedNumbers.join(', ')
                : 'None';
        });

    });

    // FORM VALIDATION
    document.getElementById('betForm').addEventListener('submit', function(e) {

        if (selectedNumbers.length !== 6) {

            e.preventDefault();

            alert('Please select exactly 6 numbers.');

            return false;
        }

    });

});
</script>
</body>
</html>
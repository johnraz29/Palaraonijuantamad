<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Place Bet</title>
    <link rel="stylesheet" href="/bet.css" />
</head>
<body>
<header>
    <div class="logo">
        <img src="/images/Logopalaronijuan.png" alt="Logo">
        <h1>Place Your Bet</h1>
    </div>
</header>

<main>
<section class="bet-section">
    <h2>Place Bet</h2>
    <p>Choose <strong>6 unique numbers</strong> between 1 and 50. Cost: ₱10</p>
    
    <form id="betForm" method="post" action="/bet">
        <div class="number-grid">
            <% for (let i = 1; i <= 50; i++) { %>
                <button type="button" class="number-btn" data-number="<%= i %>"><%= i %></button>
            <% } %>
        </div>
        <!-- Dito itatago ang 6 numbers para ma-submit sa server -->
        <input type="hidden" name="numbers" id="numbersInput" required>
        
        <div class="selected-numbers">
            <p>Selected Numbers: <span id="selectedNumbersDisplay">None</span></p>
        </div>
        <button type="submit" class="submit-btn">Place Bet (₱10)</button>
    </form>
</section>
</main>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const maxNumbers = 6;
    let selectedNumbers = [];

    const buttons = document.querySelectorAll('.number-btn');
    const numbersInput = document.getElementById('numbersInput');
    const display = document.getElementById('selectedNumbersDisplay');

    function updateUI() {
        // I-update ang hidden input value para sa server.js
        numbersInput.value = selectedNumbers.join(',');

        // I-update ang text display sa screen
        display.textContent = selectedNumbers.length ? selectedNumbers.join(', ') : 'None';

        // I-update ang kulay ng mga buttons
        buttons.forEach(btn => {
            const num = parseInt(btn.dataset.number);
            if (selectedNumbers.includes(num)) {
                btn.classList.add('selected');
            } else {
                btn.classList.remove('selected');
            }
        });
    }

    buttons.forEach(btn => {
        btn.addEventListener('click', (e) => {
            // STOP THE DEFAULT BEHAVIOR (Importante sa Railway/Mobile)
            e.preventDefault();
            e.stopPropagation();

            const num = parseInt(btn.dataset.number);
            const index = selectedNumbers.indexOf(num);

            // Kapag pinindot ulit ang numerong napili na (Toggle Off)
            if (index > -1) {
                selectedNumbers.splice(index, 1);
            } 
            // Kapag magdadagdag ng numero
            else {
                if (selectedNumbers.length < maxNumbers) {
                    selectedNumbers.push(num);
                } else {
                    alert('You can only select 6 numbers.');
                }
            }
            
            updateUI();
        });
    });

    // Validation bago i-submit ang form
    document.getElementById('betForm').addEventListener('submit', (e) => {
        if (selectedNumbers.length !== 6) {
            e.preventDefault(); // Huwag ituloy ang submit kung hindi 6 ang numbers
            alert('Please select exactly 6 numbers before placing your bet.');
        }
    });
});
</script>

<style>
    /* Siguraduhin na may visual feedback ang 'selected' class */
    .number-btn.selected {
        background-color: #ffc107 !important; /* Gold/Yellow */
        color: #000 !important;
        font-weight: bold;
        border: 2px solid #000;
    }
</style>
</body>
</html>